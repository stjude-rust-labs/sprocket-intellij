<idea-plugin>
    <id>org.stjude.sprocket</id>
    <name>Sprocket</name>
    <vendor email="support@stjude.org" url="https://github.com/stjude-rust-labs">
        St. Jude Children's Research Hospital
    </vendor>

    <description><![CDATA[
    WDL (Workflow Description Language) support powered by the Sprocket language server.

    <ul>
        <li>Syntax highlighting</li>
        <li>Real-time diagnostics</li>
        <li>Code completion</li>
        <li>Hover information</li>
        <li>Go to definition</li>
        <li>Find references</li>
        <li>Document formatting</li>
        <li>Linting (optional)</li>
    </ul>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.redhat.devtools.lsp4ij</depends>
    <depends>com.jetbrains.sh</depends>
    <depends>com.intellij.modules.json</depends>

    <actions>
        <action
            id="sprocket.run"
            class="org.stjude.sprocket.client.SprocketLSPCommandAction"
            text="Run `sprocket run`"
            description="Runs `sprocket run` on the specified target"
        />
    </actions>

    <extensions defaultExtensionNs="com.intellij">
        <fileType
                name="WDL"
                implementationClass="org.stjude.sprocket.lang.WdlFileType"
                fieldName="INSTANCE"
                language="WDL"
                extensions="wdl"/>

        <projectConfigurable
                parentId="tools"
                instance="org.stjude.sprocket.settings.SprocketConfigurable"
                id="org.stjude.sprocket.settings.SprocketConfigurable"
                displayName="Sprocket"/>

        <statusBarWidgetFactory
                id="SprocketStatusBar"
                implementation="org.stjude.sprocket.ui.SprocketStatusBarWidgetFactory"/>

        <postStartupActivity
                implementation="org.stjude.sprocket.ide.activity.SprocketStartupActivity"/>

        <notificationGroup
                id="Sprocket"
                displayType="BALLOON"/>

        <!-- Run configurations -->
        <configurationType implementation="org.stjude.sprocket.ide.execution.run.SprocketRunConfigurationType"/>
        <runConfigurationProducer
                implementation="org.stjude.sprocket.ide.execution.run.SprocketRunRunConfigurationProducer"/>

        <!-- Parser definition -->
        <lang.parserDefinition language="WDL" implementationClass="org.stjude.sprocket.lang.WdlParserDefinition"/>

        <!-- Features -->

        <!-- Call Hierarchy support -->
        <callHierarchyProvider
                language="WDL"
                implementationClass="com.redhat.devtools.lsp4ij.features.callHierarchy.LSPCallHierarchyProvider" />

        <!-- Folding range support -->
        <lang.foldingBuilder id="LSPFoldingBuilderForWdl"
                             language="WDL"
                             implementationClass="com.redhat.devtools.lsp4ij.features.foldingRange.LSPFoldingRangeBuilder"
                             order="first"/>

        <!-- Hints -->
        <codeInsight.parameterInfo
                id="LSPParameterInfoHandlerForWdl"
                language="WDL"
                order="first"
                implementationClass="com.redhat.devtools.lsp4ij.features.signatureHelp.LSPParameterInfoHandler"/>

        <!-- Syntax highlighting support -->
        <lang.syntaxHighlighterFactory
                language="WDL"
                implementationClass="org.stjude.sprocket.ide.highlight.WdlSyntaxHighlighterFactory"/>
        <annotator language="WDL" implementationClass="org.stjude.sprocket.ide.annotator.WdlHighlightingAnnotator"/>
        <multiHostInjector implementation="org.stjude.sprocket.ide.injection.WdlCommandLanguageInjector"/>
        <daemon.highlightInfoFilter implementation="org.stjude.sprocket.ide.injection.WdlCommandHighlightFilter"/>

        <codeBlockProvider language="WDL"
                           implementationClass="com.redhat.devtools.lsp4ij.features.codeBlockProvider.LSPCodeBlockProvider"
                           order="first"/>

        <!-- Commenter -->
        <lang.commenter language="WDL" implementationClass="org.stjude.sprocket.ide.typing.WdlCommenter"/>

        <!-- Matchers -->
        <lang.braceMatcher language="WDL" implementationClass="org.stjude.sprocket.ide.typing.WdlBraceMatcher"/>
        <lang.quoteHandler language="WDL" implementationClass="org.stjude.sprocket.ide.typing.WdlQuoteHandler"/>

        <!-- Handlers -->
        <enterHandlerDelegate implementation="org.stjude.sprocket.ide.typing.WdlEnterInCommandHandler"/>
        <enterBetweenBracesDelegate language="WDL"
                                    implementationClass="com.intellij.codeInsight.editorActions.enter.EnterBetweenBracesAndBracketsDelegate"/>

        <!-- TODO indexing -->
        <indexPatternBuilder implementation="org.stjude.sprocket.ide.todo.WdlTodoIndexPatternBuilder"/>
        <todoIndexer filetype="WDL" implementationClass="org.stjude.sprocket.ide.todo.WdlTodoIndexer"/>

        <!-- Formatter -->
        <lang.formatter language="WDL"
                        implementationClass="org.stjude.sprocket.ide.formatter.WdlFormattingModelBuilder"/>

        <!-- PSI management -->
        <lang.fileViewProviderFactory
                language="WDL"
                implementationClass="com.redhat.devtools.lsp4ij.features.semanticTokens.viewProvider.LSPSemanticTokensFileViewProviderFactory"/>

        <!-- Structure view -->
        <lang.psiStructureViewFactory
                id="LSPDocumentSymbolStructureViewFactoryForWdl"
                language="WDL"
                order="first"
                implementationClass="com.redhat.devtools.lsp4ij.features.documentSymbol.LSPDocumentSymbolStructureViewFactory"/>
    </extensions>

    <extensions defaultExtensionNs="com.redhat.devtools.lsp4ij">
        <server id="sprocketLanguageServer"
                name="Sprocket"
                factoryClass="org.stjude.sprocket.lsp.SprocketLanguageServerFactory">
            <description><![CDATA[
            <p>The Sprocket language server provides WDL (Workflow Description Language) support including:</p>
            <ul>
                <li>Diagnostics and validation</li>
                <li>Code completion</li>
                <li>Hover documentation</li>
                <li>Go to definition</li>
                <li>Find references</li>
                <li>Document formatting</li>
            </ul>
            ]]></description>
        </server>

        <languageMapping language="WDL" serverId="sprocketLanguageServer"/>
    </extensions>

    <actions>
        <group id="org.stjude.sprocket.SprocketGroup" text="Sprocket" popup="true">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <action id="org.stjude.sprocket.RestartServer"
                    class="org.stjude.sprocket.ui.RestartServerAction"
                    text="Restart Server"
                    description="Restart the Sprocket language server"/>
            <action id="org.stjude.sprocket.OpenSettings"
                    class="org.stjude.sprocket.ui.OpenSettingsAction"
                    text="Open Settings"
                    description="Open Sprocket settings"/>
        </group>
    </actions>
</idea-plugin>
